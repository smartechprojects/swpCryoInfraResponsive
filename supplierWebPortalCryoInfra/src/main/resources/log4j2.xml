<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%-7p %d %c %L | %m%n"/>
        </Console>
        <RollingFile name="RollingAppender"
                     fileName="${sys:catalina.base}/logs/apps/cryoInfra/cryoInfra.log"
                     filePattern="${sys:catalina.base}/logs/apps/cryoInfra/cryoInfra-%d{yyyy-MM-dd}.log">
            <!-- LOCAL: fileName="C:/temporal/cryoInfra.log" -->
            <PatternLayout pattern="%-7p %d %c %L | %m%n"/>
            <TimeBasedTriggeringPolicy/>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingAppender"/>
        </Root>
    </Loggers>
</Configuration>